PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dayliff_1000_eyes
WEBHOOK_SHARED_SECRET=change-me
ALERT_DEFAULT_RECIPIENT=operations@example.com
SLA_INTERVAL_MS=300000
ALERT_DISPATCH_INTERVAL_MS=60000
BROKER_HEALTH_INTERVAL_MS=60000
QUEUE_MAX_SIZE=10000
BROKER_PROVIDER=file-state
BROKER_STATE_FILE=server/.broker-state.json
BROKER_POLL_MS=1000
BROKER_RECLAIM_MS=30000
REDIS_STREAM_KEY=dayliff:events
REDIS_DLQ_STREAM_KEY=dayliff:events:dlq
REDIS_CONSUMER_GROUP=dayliff_ingestion
REDIS_CONSUMER_NAME=worker_1
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
OTEL_ENABLED=true
OTEL_SERVICE_NAME=dayliff-1000-eyes-server
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_METRIC_EXPORT_INTERVAL_MS=10000
SLO_EVAL_INTERVAL_MS=60000
SLO_MAX_DEAD_LETTERS=20
SLO_MAX_QUEUE_DEPTH=1000
SLO_MAX_FAILED_ALERTS_HOURLY=50
