generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JourneyStatus {
  ACTIVE
  STALLED
  COMPLETED
  CANCELLED
}

enum StageType {
  INQUIRY
  DESIGN
  QUOTATION
  DELIVERY
}

enum EventSource {
  CRM
  ENGINEERING
  ERP
  SYSTEM
}

enum EventType {
  REQUEST_CREATED
  STAGE_ENTERED
  STAGE_COMPLETED
  STATUS_UPDATED
  HANDOFF
  COMMENT_ADDED
  DOCUMENT_UPLOADED
  SLA_WARNING
  SLA_BREACH
  DELIVERY_CONFIRMED
}

enum RuleScope {
  GLOBAL
  REGION
  TEAM
}

enum AlertChannel {
  IN_APP
  EMAIL
  SMS
}

enum AlertStatus {
  PENDING
  SENT
  FAILED
  ACKNOWLEDGED
}

enum RoleName {
  SALES_ENGINEER
  BACKEND_DESIGNER
  REGIONAL_MANAGER
  ADMIN
}

model Customer {
  id               String    @id @default(cuid())
  customerCode     String?   @unique
  fullName         String
  email            String?
  phone            String?
  region           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  journeys         Journey[]

  @@index([region])
}

model Journey {
  id               String        @id @default(cuid())
  externalRef      String?       @unique
  customerId       String
  title            String
  description      String?
  currentStage     StageType     @default(INQUIRY)
  status           JourneyStatus @default(ACTIVE)
  openedAt         DateTime      @default(now())
  closedAt         DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  customer         Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  stages           JourneyStage[]
  events           JourneyEvent[]
  slaBreaches      SlaBreach[]

  @@index([customerId])
  @@index([status, currentStage])
  @@index([openedAt])
}

model JourneyStage {
  id               String    @id @default(cuid())
  journeyId        String
  stage            StageType
  sequenceNo       Int
  enteredAt        DateTime
  exitedAt         DateTime?
  ownerTeam        String?
  ownerUserId      String?
  isCurrent        Boolean   @default(false)

  journey          Journey   @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@unique([journeyId, sequenceNo])
  @@index([journeyId, stage])
  @@index([enteredAt, exitedAt])
}

model JourneyEvent {
  id               String      @id @default(cuid())
  journeyId        String
  stage            StageType?
  eventType        EventType
  source           EventSource
  sourceEventId    String
  sourceSystem     String
  occurredAt       DateTime
  receivedAt       DateTime    @default(now())
  actorUserId      String?
  actorName        String?
  payload          Json

  journey          Journey     @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@unique([source, sourceEventId])
  @@index([journeyId, occurredAt])
  @@index([eventType, occurredAt])
  @@index([source, occurredAt])
}

model SlaRule {
  id               String       @id @default(cuid())
  name             String       @unique
  description      String?
  stage            StageType
  maxDurationMins  Int
  isActive         Boolean      @default(true)
  scope            RuleScope    @default(GLOBAL)
  scopeRef         String?
  alertChannels    AlertChannel[]
  alertRecipients  String[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  breaches         SlaBreach[]

  @@index([stage, isActive])
  @@index([scope, scopeRef])
}

model SlaBreach {
  id               String      @id @default(cuid())
  journeyId        String
  ruleId           String
  stage            StageType
  breachedAt       DateTime
  resolvedAt       DateTime?
  durationMins     Int
  isResolved       Boolean     @default(false)

  journey          Journey     @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  rule             SlaRule     @relation(fields: [ruleId], references: [id], onDelete: Restrict)
  alerts           Alert[]

  @@index([journeyId, isResolved])
  @@index([ruleId, breachedAt])
}

model Alert {
  id               String       @id @default(cuid())
  breachId         String
  channel          AlertChannel
  recipient        String
  status           AlertStatus  @default(PENDING)
  sentAt           DateTime?
  errorMessage     String?
  createdAt        DateTime     @default(now())

  breach           SlaBreach    @relation(fields: [breachId], references: [id], onDelete: Cascade)

  @@index([breachId, status])
}

model InAppNotification {
  id          String   @id @default(cuid())
  recipient   String
  title       String
  message     String
  isRead      Boolean  @default(false)
  alertId     String?
  journeyId   String?
  createdAt   DateTime @default(now())

  @@index([recipient, isRead])
  @@index([createdAt])
}

model User {
  id               String      @id @default(cuid())
  email            String      @unique
  fullName         String
  region           String?
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  userRoles        UserRole[]

  @@index([region, isActive])
}

model Role {
  id               String      @id @default(cuid())
  name             RoleName    @unique
  description      String?

  rolePermissions  RolePermission[]
  userRoles        UserRole[]
}

model Permission {
  id               String      @id @default(cuid())
  code             String      @unique
  description      String?

  rolePermissions  RolePermission[]
}

model RolePermission {
  roleId           String
  permissionId     String

  role             Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission       Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId           String
  roleId           String

  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role             Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}
